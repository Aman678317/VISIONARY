rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a real environment, you'd check a dedicated 'admins' collection
      // For this demo, we'll assume a specific admin UID or a check against a collection
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Validation Blueprints ---

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'business_type', 'interest_type', 'message', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.business_type is string && data.business_type.size() > 0
        && data.interest_type in ['leasing', 'sponsorship', 'venue']
        && data.message is string && data.message.size() <= 2000
        && data.createdAt == request.time;
    }

    function isValidSection(data) {
      return data.keys().hasAll(['title', 'headline', 'description', 'order'])
        && data.title is string && data.title.size() > 0
        && data.headline is string && data.headline.size() > 0
        && data.description is string
        && data.order is int;
    }

    // --- Collections ---

    // 1. Inquiries - Write-only for public, Read for admins
    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming());
      allow read: if isAdmin();
    }

    // 2. CMS Content (Sections) - Read for everyone, Write for admins
    match /sections/{sectionId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSection(incoming());
    }

    // 3. Config (Stats) - Read for everyone, Write for admins
    match /config/stats {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // System bootstrapped or manually managed
    }
  }
}
